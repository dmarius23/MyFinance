# Backend environment — copy values from your Supabase project. DO NOT commit real secrets.
# Used by ./backend/run-local.sh (gitignored) or your deployment env.

# Supabase project base URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=

# Service-role key (SECRET) — Dashboard → Project Settings → API → service_role.
# Gates the real invite adapter; blank → the logging fallback is used (no emails sent).
SUPABASE_SERVICE_ROLE_KEY=

# JWKS endpoint for validating Supabase access tokens (ES256).
# Usually: ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URI=

# Comma-separated allowed CORS origins (the SPA origin).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Receipt-image OCR (optional). Blank → image receipts stay NEEDS_REVIEW (no LLM cost).
ANTHROPIC_API_KEY=
