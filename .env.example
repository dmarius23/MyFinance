# Copy to .env and fill in. NEVER commit real secrets (see CLAUDE.md golden rule #5).
# docker-compose reads these; the backend also accepts them as plain env vars.

# --- Database (local dev defaults match docker-compose) ---
DB_URL=jdbc:postgresql://localhost:5432/myfinance
DB_APP_USER=myfinance_app
DB_APP_PASSWORD=myfinance_app
DB_ADMIN_URL=jdbc:postgresql://localhost:5432/myfinance
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=postgres

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth (Supabase) ---
# Your project's JWKS endpoint. Until set, secured API endpoints return 401.
SUPABASE_JWKS_URI=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8080
# Supabase client (frontend) — anon key is public by design, but keep it out of git.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
