# Frontend environment — copy to .env.local and fill from your Supabase project.
# These are baked into the bundle at build time. The anon key is public (not a secret),
# but never put the service-role key here.

# Supabase project base URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key — Dashboard → Project Settings → API → anon public.
VITE_SUPABASE_ANON_KEY=

# Backend API base URL (Spring app). Empty = same origin.
VITE_API_BASE_URL=http://localhost:8080
